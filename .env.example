# Database (sqlite | mysql)
DB_DRIVER=sqlite
DB_PATH=hitokoto.db

# MySQL settings (used when DB_DRIVER=mysql)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=hitokoto
DB_SSLMODE=disable

# JWT
JWT_SECRET=your-access-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production

# Server
SERVER_PORT=8080
